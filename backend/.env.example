# Parlo backend secrets.
#
# Copy this file to `.env` (in the same directory you run the server from) and
# fill in the values. The server reads it at startup via pydantic-settings.
#
# This file contains ONLY secrets. All other configuration — the model list,
# CORS origins, database path, image storage — lives in `config.yaml`, which
# is safe to commit to version control. This file must stay git-ignored.

# Shared bearer token that the Flutter client must present on every request.
# Generate a long random string, for example:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=change-me-to-a-long-random-string

# API keys for the upstream providers. Each model in `config.yaml` references
# one of these by name in its `api_key` field. Add as many as the models you
# configure; only the ones referenced by some model need to be set.

# OpenAI API key. Referenced by models with `api_key: OPENAI_API_KEY`.
OPENAI_API_KEY=sk-...

# Anthropic API key. Referenced by models with `api_key: ANTHROPIC_API_KEY`.
ANTHROPIC_API_KEY=sk-ant-...
